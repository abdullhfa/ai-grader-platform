# =====================================================
#  BTEC IT Auto-Grader — Environment Configuration
#  Copy this file to `.env` and fill in the real values.
#  NEVER commit `.env` to version control.
# =====================================================

# =====================================================
#  AI PROVIDER (REQUIRED — pick ONE)
# =====================================================
# Options the code supports: gemini, openrouter, ollama
AI_PROVIDER=gemini

# --- Option A: Gemini directly (recommended, free tier available) ---
# Get a key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# BASIC (fast batch) — speed
GEMINI_MODEL=gemini-2.5-flash
# PRO (deep / BTEC evidence) — reasoning quality (override for grading_mode=deep)
GEMINI_PRO_MODEL=gemini-2.5-pro
# Note: Gemini 2.5 Flash uses thinking tokens — keep GEMINI_MIN_OUTPUT_TOKENS >= 128
# GEMINI_MIN_OUTPUT_TOKENS=128

# Batch grading parallelism
FAST_BATCH_PARALLEL_STUDENTS=8
PRO_BATCH_PARALLEL_STUDENTS=2
BASIC_MAX_VISION_IMAGES=10
PRO_MAX_VISION_IMAGES=5
PRO_MAX_VISION_IMAGES_DOC=3
PRO_MAX_VISION_IMAGES_GAME=5
# 1 = skip GameMaker/browser runtime (faster). 0 = PRO runs the game (default, required for P5-P6-P7).
PRO_FAST_PATH=0
# Block Merit/Distinction auto-award when C.P6 evidence coverage is below this % (default 50).
PRO_CP6_COVERAGE_MERIT_MIN=50

# --- Option B: OpenRouter (set AI_PROVIDER=openrouter to use) ---
# Get a key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_PRO_MODEL=google/gemini-2.5-pro

# --- Option C: Ollama (LOCAL DEV ONLY — never on a cloud server) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=deepseek-coder

# IMPORTANT for production deployments:
# Set this to true so the system doesn't try to fall back to a local Ollama
# instance that isn't there. Without this, a Gemini failure becomes a
# confusing "Connection refused to localhost:11434" error.
DISABLE_OLLAMA_FALLBACK=true

# =====================================================
#  DATABASE (REQUIRED)
# =====================================================
DATABASE_URL=sqlite:///./ai_grader.db
# For production prefer MySQL:
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/ai_grader

# =====================================================
#  SERVER (REQUIRED)
# =====================================================
HOST=0.0.0.0
PORT=5556
DEBUG=False

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_BEFORE_DEPLOYING
# Set PRODUCTION=true on live servers (requires SECRET_KEY; enables secure cookies)
PRODUCTION=false
COOKIE_SECURE=false

# Login brute-force lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

AI_DETECTION_DETERMINISTIC_ONLY=0
# AI content detection sample size (chars sent to LLM when hybrid detection enabled)
AI_DETECTION_SAMPLE_CHARS=12000

# =====================================================
#  APPLICATION (OPTIONAL)
# =====================================================
APP_TITLE=أداة تصحيح واجبات Pearson BTEC IT
GUIDE_MAX_WORKERS=3
# Batch / folder uploads: Starlette defaults to 1000 multipart file parts per request.
# Raise if you upload student folders with many files (each file is one part).
MULTIPART_MAX_FILES=8000
MULTIPART_MAX_FIELDS=8000
# Safety ceiling: effective caps passed to Starlette are min(MULTIPART_*, this value).
MULTIPART_HARD_CEILING=12000

# Ingestion guardrails (operational — reject before batch record)
# Max number of multipart parts per /api/batch-grade request.
INGESTION_MAX_MULTIPART_FILES=24000
# Max total uploaded bytes per request (default 4 GiB).
INGESTION_MAX_UPLOAD_BYTES_TOTAL=4294967296
# If this fraction of paths match ignore rules (Library, obj, …), flag excessive_runtime_artifacts.
INGESTION_EXCESSIVE_IGNORE_RATIO=0.45
INGESTION_HIGH_FILE_COUNT_WARNING=8000

# =====================================================
#  GOOGLE OAUTH (OPTIONAL — only if you want "Sign in with Google")
# =====================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5556/auth/google/callback

# =====================================================
#  WHATSAPP (OPTIONAL — activation & subscription notifications)
# =====================================================
# Default sender/account phone (Jordan local format). Change later from Admin → WhatsApp.
WHATSAPP_DEFAULT_PHONE=0786060100
WHATSAPP_SERVICE_URL=http://localhost:3001
WHATSAPP_AUTO_START=true
WA_PORT=3001
# Legacy Cloud API (unused when whatsapp-web.js sidecar is active):
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
