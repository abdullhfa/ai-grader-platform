# =====================================================
#  Secrets — NEVER commit these
# =====================================================
.env
.env.local
.env.*.local
*.pem
*.key

# =====================================================
#  Python build / cache artefacts
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Local wheels cache (e.g. Python 3.14 Windows wheels — irrelevant on Linux servers)
tmp_wheels/

# Virtual environments
.venv/
venv/
env/
ENV/

# Node.js dependencies (Scratch runtime scripts, WhatsApp service, etc.)
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo
.pyrightconfig.json
.mypy_cache/
.ruff_cache/
.pytest_cache/

# OS
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
#  Runtime data — generated by the app, not source code
# =====================================================
ai_grader.db
ai_grader.db-journal
ai_grader.db-wal
ai_grader.db-shm
*.log

# Student submissions, generated reports, debug dumps
uploads/students/
uploads/assignments/
uploads/reports/
uploads/debug/
uploads/textbooks/

# The templates folder itself stays in version control; only its cache is ignored
uploads/specification/cache/
debug_ai_*.txt
recent_grade_response.txt

# =====================================================
#  WhatsApp service runtime data (NEVER commit these — they contain session tokens!)
# =====================================================
whatsapp_service/node_modules/
whatsapp_service/wa_session/
whatsapp_service/.wwebjs_cache/
whatsapp_service/.wwebjs_auth/
whatsapp_service/*.log

# =====================================================
#  Misc
# =====================================================
*.bak
*.tmp
.coverage
htmlcov/
