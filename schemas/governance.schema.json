{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-grader.local/schemas/governance.schema.json",
  "title": "GovernanceSignoff",
  "type": "object",
  "required": ["submission_key", "session_id", "replay_hash", "signed_evaluation_hash"],
  "properties": {
    "submission_key": { "type": "string" },
    "session_id": { "type": "string" },
    "examiner_id": { "type": "string" },
    "final_grade": { "type": "string" },
    "replay_hash": { "type": "string" },
    "signed_evaluation_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string" },
    "reason": { "type": "string" }
  }
}
